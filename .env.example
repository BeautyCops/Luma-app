# من Supabase → Settings → API (انسخي إلى .env محلياً)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...anon...
VITE_SUPABASE_PROJECT_ID=xxxx

# أسماء بديلة إذا ربطتِ Supabase بـ GitHub (نفس القيم)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...anon...
SUPABASE_PROJECT_ID=xxxx

# لتشغيل: node scripts/setup-admin.mjs
# استخدمي Legacy service_role (يبدأ بـ eyJ) — ليس sb_secret_
SUPABASE_SERVICE_ROLE_KEY=eyJ...legacy_service_role_jwt...

# لضبط روابط التأكيد (بدون Lovable): node scripts/configure-auth.mjs
SUPABASE_ACCESS_TOKEN=sbp_...

# Netlify Functions (تسجيل فوري): أضيفي نفس service_role في Netlify → Environment variables
